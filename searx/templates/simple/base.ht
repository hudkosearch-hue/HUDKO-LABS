<!DOCTYPE html>
<html class="no-js theme-{{ preferences.get_value('simple_style') or 'auto' }}">
<head>
  <meta charset="UTF-8">
  <meta name="endpoint" content="{{ endpoint }}">
  <meta name="description" content="HUDKO Search — a privacy-respecting, open search engine">
  <meta name="keywords" content="HUDKO Search, search, search engine, privacy, Karnataka">
  <meta name="generator" content="searxng/{{ searxng_version }}">
  <meta name="referrer" content="no-referrer">
  <meta name="robots" content="noarchive">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>HUDKO Search</title>
  <script type="module" src="{{ url_for('static', filename='sxng-core.min.js') }}"></script>
  {% block meta %}{% endblock %}
  {% if rtl %}
  <link rel="stylesheet" href="{{ url_for('static', filename='sxng-rtl.min.css') }}">
  {% else %}
  <link rel="stylesheet" href="{{ url_for('static', filename='sxng-ltr.min.css') }}">
  {% endif %}
  {% if get_setting('server.limiter') or get_setting('server.public_instance') %}
  <link rel="stylesheet" href="{{ url_for('client_token', token=link_token) }}">
  {% endif %}
  {% block head %}
  <link title="{{ instance_name }}" type="application/opensearchdescription+xml" rel="search" href="{{ url_for('opensearch') }}">
  {% endblock %}
  <link rel="icon" href="{{ url_for('static', filename='img/favicon.png') }}">
  <link rel="icon" href="{{ url_for('static', filename='img/favicon.svg') }}">
  <link rel="manifest" href="{{ url_for('manifest') }}" />
</head>
<body class="{{ endpoint }}_endpoint">
  <main id="main_{{ self._TemplateReference__context.name|replace("simple/", "") }}">
    {% if errors %}
        <div class="dialog-error" role="alert">
            <a href="#" class="close" aria-label="close" title="close">×</a>
            <ul>
            {% for message in errors %}
                <li>{{ message }}</li>
            {% endfor %}
            </ul>
        </div>
    {% endif %}
    
    <nav id="links_on_top">
      {%- from 'simple/icons.html' import icon_big -%}
      {%- block linkto_about -%}
        <a href="{{ url_for('info', pagename='about') }}" class="link_on_top_about">{{ icon_big('info') }}</a>
      {%- endblock -%}
      {%- block linkto_donate -%}
        {%- if donation_url -%}
        <a href="{{ donation_url }}" class="link_on_top_donate">{{ icon_big('heart') }}</a>
        {%- endif -%}
      {%- endblock -%}
      {%- block linkto_preferences -%}
        {%- if request.args.get('preferences') -%}
          <a href="{{ url_for('preferences') }}?preferences={{ request.args.get('preferences') }}" class="link_on_top_preferences">{{ icon_big('cog') }}</a>
        {%- else -%}
          <a href="{{ url_for('preferences') }}" class="link_on_top_preferences">{{ icon_big('cog') }}</a>
        {%- endif -%}
      {%- endblock -%}
    </nav>
    
    {% block header %}
    {% endblock %}
    
    {% block content %}
    {% endblock %}
  </main>

  <footer>
    <div style="text-align:center;padding:20px;margin-top:20px;border-top:2px solid #FFD700;">
        <h3 style="color:#c8102e;margin-bottom:10px;">HUDKO Search</h3>
        <p>Powered by <strong>HUDKO LABS</strong></p>
        <p style="color:#c8102e;font-weight:bold;">
            Made in Karnataka | Manipal | Kundapura
        </p>
        <p style="font-size:12px;opacity:0.8;">Privacy Focused Search Engine</p>
        <p style="font-size:12px;opacity:0.7;">© 2026 HUDKO LABS. All Rights Reserved.</p>
    </div>
  </footer>
</body>
</html>


